{
  "schemaVersion": 1,
  "id": "lepidoptera-api",
  "version": "${version}",
  "name": "Lepidoptera API",
  "description": "Provides common functionality for satyrnidae's mods.",
  "authors": [
    "satyrnidae"
  ],
  "contact": {
    "homepage": "https://satyrn.dev/",
    "sources": "https://github.com/satyrnidae/lepidopterapi"
  },
  "license": "MIT",
  "icon": "icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "dev.satyrn.lepidoptera.fabric.MainEntrypoint"
    ],
    "client": [
      "dev.satyrn.lepidoptera.fabric.client.ClientEntrypoint"
    ],
    "modmenu": [
      "dev.satyrn.lepidoptera.fabric.client.ModMenuApiImpl"
    ]
  },
  "mixins": [
    "lepidoptera.api.mixins.json",
    "lepidoptera.common.mixins.json",
    "lepidoptera.fabric.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.16.10",
    "minecraft": "~1.21.1",
    "java": ">=21",
    "architectury": ">=13.0.6",
    "fabric-api": "*"
  },
  "suggests": {
    "cloth-config": ">=15.0.140",
    "modmenu": ">=11.0.3"
  }
}
